      "status": "translated",
      "inlines": [
        {
          "type": "strong",
          "children": [
            {
              "type": "text",
              "text": "拒绝采样 + 非推理SFT"
            }
          ]
        },
        {
          "type": "text",
          "text": "利用在步骤2的RL检查点上通过拒绝采样创建的新SFT数据，结合来自"
