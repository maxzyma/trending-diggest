                {
                  "type": "text",
                  "text": "根滤波器"
                }
              ]
            }
          ]
        },
        {
          "type": "text",
          "text": "定义了一个大致覆盖整个对象的检测窗口。滤波器为区域特征向量指定权重。"
        }
      ]
    },
    "list-item-c64faa00886f": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "多个"
        },
        {
          "type": "emphasis",
          "children": [
            {
              "type": "strong",
              "children": [
