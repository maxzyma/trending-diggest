                  "type": "text",
                  "text": "空间模型"
                }
              ]
            }
          ]
        },
        {
          "type": "text",
          "text": "用于评估部件滤波器相对于根的位置。"
        }
      ]
    },
    "paragraph-c12d6b70795f": {
      "status": "translated",
      "inlines": [
        {
