    "paragraph-c878b2961ba7": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "(1) 正如教程"
        },
        {
          "type": "link",
          "attrs": {
            "url": "https://lilianweng.github.io/posts/2017-07-08-stock-rnn-part-1/#define-graph"
