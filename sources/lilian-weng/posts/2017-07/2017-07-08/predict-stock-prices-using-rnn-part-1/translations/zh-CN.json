    "paragraph-3c69738425b7": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "在阅读了大量示例之后，我建议以 Penn Tree Bank (PTB) 数据集上的"
        },
        {
          "type": "link",
          "attrs": {
