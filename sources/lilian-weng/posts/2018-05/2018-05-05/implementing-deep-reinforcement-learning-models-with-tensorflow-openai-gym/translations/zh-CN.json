          "text": "。"
        }
      ]
    },
    "heading-e581f013760f": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "Actor-Critic"
        }
      ]
    },
    "paragraph-b917c622341b": {
      "status": "translated",
      "inlines": [
        {
          "type": "link",
          "attrs": {
            "url": "https://lilianweng.github.io/posts/2018-04-08-policy-gradient/#actor-critic"
          },
          "children": [
            {
              "type": "text",
              "text": "Actor-critic"
            }
          ]
        },
        {
          "type": "text",
          "text": " 算法同时学习两个模型：actor 用于学习最佳策略，critic 用于估计状态值。"
        }
      ]
    },
    "list-item-09ec70ee9a90": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "初始化 actor 网络 "
        },
        {
          "type": "inline_math",
          "text": "\\pi(a \\vert s)"
        },
        {
          "type": "text",
          "text": " 和 critic "
        },
        {
          "type": "inline_math",
          "text": "V(s)"
        }
      ]
    },
    "list-item-1c26971bc443": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "收集新的转换 (s, a, r, s’): 为当前状态 s 采样动作 "
        },
        {
          "type": "inline_math",
          "text": "a \\sim \\pi(a \\vert s)"
        },
        {
          "type": "text",
          "text": "，并获得奖励 r 和下一个状态 s'。"
        }
      ]
    },
    "list-item-6c59e4e4975d": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "在回合展开期间计算 TD 目标 "
        },
        {
          "type": "inline_math",
          "text": "G_t = r + \\gamma V(s’)"
        },
        {
          "type": "text",
          "text": " 和 TD 误差 "
        },
        {
          "type": "inline_math",
          "text": "\\delta_t = r + \\gamma V(s’) - V(s)"
        },
        {
          "type": "text",
          "text": "。"
        }
      ]
    },
    "list-item-4cf03aa36171": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "通过最小化 critic 损失来更新 critic 网络："
        },
        {
          "type": "inline_math",
          "text": "L_c = (V(s) - G_t)"
        },
        {
          "type": "text",
          "text": "。"
        }
      ]
    },
    "list-item-a71100a05753": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "通过最小化 actor 损失来更新 actor 网络："
        },
        {
          "type": "inline_math",
          "text": "L_a = - \\delta_t \\log \\pi(a \\vert s)"
        },
        {
          "type": "text",
          "text": "。"
        }
      ]
    },
    "list-item-9d1e02fcec97": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "设置 s’ = s 并重复步骤 2-5。"
        }
      ]
    },
    "paragraph-408ceb0600e4": {
      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "总的来说，该实现与带有额外 critic 网络的 REINFORCE 非常相似。完整实现请见此处。"
        }
      ]
    },
