      "status": "translated",
      "inlines": [
        {
          "type": "text",
          "text": "现在，问题是 "
        },
        {
          "type": "emphasis",
          "children": [
            {
              "type": "text",
              "text": "如何估计置信上限"
            }
          ]
        },
        {
          "type": "text",
          "text": "。"
        }
      ]
    },
